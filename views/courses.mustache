{{> head}}
{{> header}}

<section class="filters">
  <form method="get" action="/courses">
    <div class="form-group">
      <label for="level">Level</label>
      <select id="level" name="level">
        <option value="">Any</option>
        <option value="beginner">Beginner</option>
        <option value="intermediate">Intermediate</option>
        <option value="advanced">Advanced</option>
      </select>
    </div>

    <div class="form-group">
      <label for="q">Search</label>
      <input
        type="search"
        id="q"
        name="q"
        value="{{filters.q}}"
        placeholder="Title or description"
      />
    </div>

    <button class="btn" type="submit">Apply</button>
    <a href="/courses">Reset</a>
  </form>
</section>

<div class="cards">
  {{#courses}}
  <article class="card">
    <h2><a href="/courses/{{id}}">{{title}}</a></h2>
    <p class="muted">
      Level: {{level}} • Type: {{type}} {{#allowDropIn}}• Drop-in OK{{/allowDropIn}}
    </p>
    <p>{{description}}</p>
    <p class="muted">Dates: {{startDate}} – {{endDate}}</p>
    <p class="muted">Location: {{location}}</p>
    <p class="muted">Price: {{price}}</p>
    <p class="muted">Next session: {{nextSession}} • Sessions: {{sessionsCount}}</p>
    <p><a href="/courses/{{id}}">View &amp; Book</a></p>
  </article>
  {{/courses}}

  {{^courses}}
    <p>No courses match your filters.</p>
  {{/courses}}
</div>

<nav class="pagination">
  {{#pagination.hasPrev}}
    <a href="{{pagination.prevLink}}">← Previous</a>
  {{/pagination.hasPrev}}

  <span class="muted">Page {{pagination.page}} of {{pagination.totalPages}}</span>

  {{#pagination.hasNext}}
    <a href="{{pagination.nextLink}}">Next →</a>
  {{/pagination.hasNext}}
</nav>

{{> footer}}